rules_version = '2';

function isAdmin() {
  return request.auth != null && request.auth.uid == get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.uid;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own profile.
    // Public reads are allowed only if a profile status is 'approved'.
    // Admins can read any user profile.
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || 
                     resource.data.profileStatus == 'approved' ||
                     isAdmin();
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Admins can read the list of admins
    match /admins/{adminId} {
      allow read: if isAdmin();
      // Lock down admin creation/deletion to prevent unauthorized changes
      allow write: if false; 
    }
  }
}