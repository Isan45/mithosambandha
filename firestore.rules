rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for Role-Based Access Control (RBAC)
    function isUser(uid) {
      return request.auth.uid == uid;
    }

    function isSuperAdmin(uid) {
      return exists(/databases/$(database)/documents/admins/$(uid));
    }

    function isAdmin(uid) {
      return isSuperAdmin(uid);
    }

    function isModerator(uid) {
      return exists(/databases/$(database)/documents/moderators/$(uid)) || isAdmin(uid);
    }

    // ---- PRIMARY USER COLLECTION ----
    // This is the main collection used by the app for user profiles.
    // Users can read approved profiles, their own profile, or admins can read any.
    // Users can only update their own profile and cannot modify role or profileStatus fields.
    match /users/{uid} {
      allow read: if resource.data.profileStatus == 'approved'
                   || isUser(uid)
                   || isAdmin(request.auth.uid);

      allow create: if request.auth.uid == uid;

      allow update: if (isUser(uid) && !('role' in request.resource.data) && !('profileStatus' in request.resource.data))
                   || isAdmin(request.auth.uid);

      allow delete: if isAdmin(request.auth.uid);
    }

    // A separate collection for user data that should be private.
    match /privateUserData/{uid} {
      allow read, write: if isUser(uid) || isAdmin(request.auth.uid);
    }

    // Users can submit reports, but only moderators/admins can manage them.
    match /reports/{reportId} {
      allow create: if request.auth.uid != null;
      allow read, update, delete: if isModerator(request.auth.uid);
    }

    // Users can create verification requests, but only admins can act on them.
    match /verifications/{verificationId} {
      allow create: if request.auth.uid != null;
      allow read, update: if isAdmin(request.auth.uid);
    }

    // Audit logs are write-only for server-side (Admin SDK) operations, and read-only for admins.
    match /auditLogs/{logId} {
      allow read: if isAdmin(request.auth.uid);
      allow write: if false; // Only written from trusted server environment (Admin SDK)
    }

    // Configuration can be read by any authenticated user, but only written by a super admin.
    match /config/{configId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin(request.auth.uid);
    }

    // Matches can be read by the users involved or by an admin.
    match /matches/{matchId} {
      allow read: if request.auth.uid in resource.data.uids || isAdmin(request.auth.uid);
      allow create, update, delete: if false; // Matches created by server functions
    }

    // Admin/moderator role collections.
    match /admins/{uid} {
      allow read, write: if isSuperAdmin(request.auth.uid);
    }

    match /moderators/{uid} {
      allow read, write: if isAdmin(request.auth.uid);
    }
  }
}
